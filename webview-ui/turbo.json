{
	"$schema": "https://turbo.build/schema.json",
	"extends": ["//"],
	"tasks": {
		"build": {
			"outputs": ["../src/webview-ui/**"],
			"inputs": [
				"src/**",
				"package.json",
				"tsconfig.json",
				"tsup.config.ts",
				"vite.config.ts",
				"../src/package.json"
			]
		},
		"build:nightly": {
			"outputs": ["../apps/vscode-nightly/build/webview-ui/**"]
		}
	}
}
