{
	"name": "@shofer/cli",
	"version": "0.1.18",
	"description": "Shofer CLI - Run the Shofer agent from the command line",
	"private": true,
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"shofer": "dist/index.js"
	},
	"scripts": {
		"format": "prettier --write 'src/**/*.ts'",
		"lint": "eslint src --ext .ts --max-warnings=0",
		"check-types": "tsc --noEmit",
		"test": "vitest run",
		"test:integration": "tsx scripts/integration/run.ts",
		"build": "tsup",
		"build:extension": "pnpm --filter shofer bundle",
		"dev": "SHOFER_AUTH_BASE_URL=https://app.shofer.dev SHOFER_SDK_BASE_URL=https://cloud-api.shofer.dev SHOFER_PROVIDER_URL=https://api.shofer.dev/proxy tsx src/index.ts",
		"dev:local": "SHOFER_AUTH_BASE_URL=http://localhost:3000 SHOFER_SDK_BASE_URL=http://localhost:3001 SHOFER_PROVIDER_URL=http://localhost:8080/proxy tsx src/index.ts",
		"dev:local-router": "tsx src/index.ts --provider shofer --api-key x --base-url http://localhost:30081/v1 --model arkware/deepseek_deepseek-v4-pro",
		"clean": "rimraf dist .turbo"
	},
	"dependencies": {
		"@inkjs/ui": "^2.0.0",
		"@shofer/core": "workspace:^",
		"@shofer/types": "workspace:^",
		"@shofer/vscode-shim": "workspace:^",
		"@trpc/client": "^11.8.1",
		"@vscode/ripgrep": "^1.15.9",
		"commander": "^12.1.0",
		"cross-spawn": "^7.0.6",
		"execa": "^9.5.2",
		"fuzzysort": "^3.1.0",
		"ink": "^6.6.0",
		"p-wait-for": "^5.0.2",
		"react": "^19.1.0",
		"superjson": "^2.2.6",
		"zustand": "^5.0.0"
	},
	"devDependencies": {
		"@shofer/config-eslint": "workspace:^",
		"@shofer/config-typescript": "workspace:^",
		"@types/node": "^24.1.0",
		"@types/react": "^19.1.6",
		"ink-testing-library": "^4.0.0",
		"rimraf": "^6.0.1",
		"tsup": "^8.4.0",
		"vitest": "^3.2.3"
	}
}
