{
	"name": "shofer",
	"displayName": "Shofer",
	"description": "%extension.description%",
	"publisher": "Shoferdev",
	"version": "1.0.13",
	"icon": "assets/icons/icon128x128.png",
	"galleryBanner": {
		"color": "#1e293b",
		"theme": "dark"
	},
	"engines": {
		"vscode": "^1.84.0",
		"node": "20.19.2"
	},
	"author": {
		"name": "Shofer"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/shofer-dev/shofer"
	},
	"homepage": "https://shofer.dev",
	"bugs": {
		"url": "https://github.com/shofer-dev/shofer/issues"
	},
	"pricing": "Free",
	"license": "Apache-2.0",
	"sponsor": {
		"url": "https://github.com/sponsors/alsterg"
	},
	"categories": [
		"AI",
		"Chat",
		"Programming Languages",
		"Education",
		"Snippets",
		"Testing"
	],
	"keywords": [
		"shofer",
		"claude",
		"dev",
		"mcp",
		"openrouter",
		"coding",
		"agent",
		"autonomous",
		"chatgpt",
		"sonnet",
		"ai",
		"llama"
	],
	"activationEvents": [
		"onLanguage",
		"onStartupFinished"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "shofer-ActivityBar",
					"title": "%views.activitybar.title%",
					"icon": "assets/icons/icon.svg"
				}
			]
		},
		"views": {
			"shofer-ActivityBar": [
				{
					"type": "webview",
					"id": "shofer.SidebarProvider",
					"name": "%views.sidebar.name%"
				},
				{
					"type": "tree",
					"id": "shofer.contextDropZone",
					"name": "%views.dropZone.name%",
					"initialSize": 1
				}
			]
		},
		"commands": [
			{
				"command": "shofer.plusButtonClicked",
				"title": "%command.newTask.title%",
				"icon": "$(add)"
			},
			{
				"command": "shofer.tasksButtonClicked",
				"title": "%command.tasks.title%",
				"icon": "$(list-tree)"
			},
			{
				"command": "shofer.historyButtonClicked",
				"title": "%command.history.title%",
				"icon": "$(history)"
			},
			{
				"command": "shofer.marketplaceButtonClicked",
				"title": "%command.marketplace.title%",
				"icon": "$(extensions)"
			},
			{
				"command": "shofer.popoutButtonClicked",
				"title": "%command.openInEditor.title%",
				"icon": "$(link-external)"
			},
			{
				"command": "shofer.settingsButtonClicked",
				"title": "%command.settings.title%",
				"icon": "$(settings-gear)"
			},
			{
				"command": "shofer.openInNewTab",
				"title": "%command.openInNewTab.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "shofer.explainCode",
				"title": "%command.explainCode.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "shofer.fixCode",
				"title": "%command.fixCode.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "shofer.improveCode",
				"title": "%command.improveCode.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "shofer.addToContext",
				"title": "%command.addToContext.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "shofer.newTask",
				"title": "%command.newTask.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "shofer.terminalAddToContext",
				"title": "%command.terminal.addToContext.title%",
				"category": "Terminal"
			},
			{
				"command": "shofer.terminalFixCommand",
				"title": "%command.terminal.fixCommand.title%",
				"category": "Terminal"
			},
			{
				"command": "shofer.terminalExplainCommand",
				"title": "%command.terminal.explainCommand.title%",
				"category": "Terminal"
			},
			{
				"command": "shofer.setCustomStoragePath",
				"title": "%command.setCustomStoragePath.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "shofer.importSettings",
				"title": "%command.importSettings.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "shofer.focusInput",
				"title": "%command.focusInput.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "shofer.acceptInput",
				"title": "%command.acceptInput.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "shofer.toggleAutoApprove",
				"title": "%command.toggleAutoApprove.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "shofer.addFilesToContext",
				"title": "Add to Shofer Context",
				"category": "%configuration.title%"
			},
			{
				"command": "shofer.assistantAgent.showChat",
				"title": "Show Assistant Agent Chat",
				"category": "%configuration.title%"
			},
			{
				"command": "shofer.assistantAgent.start",
				"title": "Start Assistant Agent",
				"category": "%configuration.title%"
			},
			{
				"command": "shofer.assistantAgent.stop",
				"title": "Stop Assistant Agent",
				"category": "%configuration.title%"
			},
			{
				"command": "shofer.assistantAgent.clearContext",
				"title": "Clear Assistant Agent Context",
				"category": "%configuration.title%"
			},
			{
				"command": "shofer.refreshWebview",
				"title": "%command.refreshWebview.title%",
				"icon": "$(refresh)",
				"category": "%configuration.title%"
			},
			{
				"command": "shofer.reloadWindow",
				"title": "%command.reloadWindow.title%",
				"icon": "$(debug-restart)",
				"category": "%configuration.title%"
			},
			{
				"command": "shofer.walkthrough.open",
				"title": "%walkthrough.open.title%",
				"category": "%configuration.title%",
				"icon": "$(symbol-event)"
			},
			{
				"command": "shofer.walkthrough.openDocumentation",
				"title": "%walkthrough.openDocumentation.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "shofer.walkthrough.joinDiscord",
				"title": "%walkthrough.joinDiscord.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "shofer.walkthrough.openCopilotGuide",
				"title": "%walkthrough.openCopilotGuide.title%",
				"category": "%configuration.title%"
			},
			{
				"command": "shofer.walkthrough.openRoocodeGuide",
				"title": "%walkthrough.openRoocodeGuide.title%",
				"category": "%configuration.title%"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "shofer.plusButtonClicked",
					"group": "navigation@1",
					"when": "view == shofer.SidebarProvider"
				},
				{
					"command": "shofer.tasksButtonClicked",
					"group": "navigation@2",
					"when": "view == shofer.SidebarProvider"
				},
				{
					"command": "shofer.settingsButtonClicked",
					"group": "navigation@3",
					"when": "view == shofer.SidebarProvider"
				},
				{
					"command": "shofer.marketplaceButtonClicked",
					"group": "navigation@5",
					"when": "view == shofer.SidebarProvider && shofer:marketplaceEnabled"
				},
				{
					"command": "shofer.historyButtonClicked",
					"group": "overflow@1",
					"when": "view == shofer.SidebarProvider"
				},
				{
					"command": "shofer.popoutButtonClicked",
					"group": "overflow@2",
					"when": "view == shofer.SidebarProvider"
				},
				{
					"command": "shofer.refreshWebview",
					"group": "overflow@3",
					"when": "view == shofer.SidebarProvider && shofer:webviewLivenessMonitorEnabled"
				},
				{
					"command": "shofer.reloadWindow",
					"group": "overflow@4",
					"when": "view == shofer.SidebarProvider && shofer:webviewLivenessMonitorEnabled"
				},
				{
					"command": "shofer.walkthrough.open",
					"group": "overflow@5",
					"when": "view == shofer.SidebarProvider"
				}
			],
			"editor/context": [
				{
					"submenu": "shofer.contextMenu",
					"group": "1"
				}
			],
			"explorer/context": [
				{
					"command": "shofer.addFilesToContext",
					"group": "9_shofer@1"
				}
			],
			"shofer.contextMenu": [
				{
					"command": "shofer.addToContext",
					"group": "1_actions@1"
				},
				{
					"command": "shofer.explainCode",
					"group": "1_actions@2"
				},
				{
					"command": "shofer.improveCode",
					"group": "1_actions@3"
				}
			],
			"terminal/context": [
				{
					"submenu": "shofer.terminalMenu",
					"group": "2"
				}
			],
			"shofer.terminalMenu": [
				{
					"command": "shofer.terminalAddToContext",
					"group": "1_actions@1"
				},
				{
					"command": "shofer.terminalFixCommand",
					"group": "1_actions@2"
				},
				{
					"command": "shofer.terminalExplainCommand",
					"group": "1_actions@3"
				}
			],
			"editor/title": [
				{
					"command": "shofer.plusButtonClicked",
					"group": "navigation@1",
					"when": "activeWebviewPanelId == shofer.TabPanelProvider"
				},
				{
					"command": "shofer.tasksButtonClicked",
					"group": "navigation@2",
					"when": "activeWebviewPanelId == shofer.TabPanelProvider"
				},
				{
					"command": "shofer.settingsButtonClicked",
					"group": "navigation@3",
					"when": "activeWebviewPanelId == shofer.TabPanelProvider"
				},
				{
					"command": "shofer.marketplaceButtonClicked",
					"group": "navigation@5",
					"when": "activeWebviewPanelId == shofer.TabPanelProvider && shofer:marketplaceEnabled"
				},
				{
					"command": "shofer.historyButtonClicked",
					"group": "overflow@1",
					"when": "activeWebviewPanelId == shofer.TabPanelProvider"
				},
				{
					"command": "shofer.popoutButtonClicked",
					"group": "overflow@2",
					"when": "activeWebviewPanelId == shofer.TabPanelProvider"
				},
				{
					"command": "shofer.refreshWebview",
					"group": "overflow@3",
					"when": "activeWebviewPanelId == shofer.TabPanelProvider && shofer:webviewLivenessMonitorEnabled"
				},
				{
					"command": "shofer.reloadWindow",
					"group": "overflow@4",
					"when": "activeWebviewPanelId == shofer.TabPanelProvider && shofer:webviewLivenessMonitorEnabled"
				}
			]
		},
		"keybindings": [
			{
				"command": "shofer.addToContext",
				"key": "cmd+k cmd+a",
				"mac": "cmd+k cmd+a",
				"win": "ctrl+k ctrl+a",
				"linux": "ctrl+k ctrl+a",
				"when": "editorTextFocus && editorHasSelection"
			},
			{
				"command": "shofer.toggleAutoApprove",
				"key": "cmd+alt+a",
				"mac": "cmd+alt+a",
				"win": "ctrl+alt+a",
				"linux": "ctrl+alt+a"
			}
		],
		"submenus": [
			{
				"id": "shofer.contextMenu",
				"label": "%views.contextMenu.label%"
			},
			{
				"id": "shofer.terminalMenu",
				"label": "%views.terminalMenu.label%"
			}
		],
		"configuration": {
			"title": "%configuration.title%",
			"properties": {
				"shofer.allowedCommands": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [
						"git log",
						"git diff",
						"git show"
					],
					"description": "%commands.allowedCommands.description%"
				},
				"shofer.deniedCommands": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "%commands.deniedCommands.description%"
				},
				"shofer.devmandExecutionTimeout": {
					"type": "number",
					"default": 0,
					"minimum": 0,
					"maximum": 600,
					"description": "%commands.commandExecutionTimeout.description%"
				},
				"shofer.devmandTimeoutAllowlist": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "%commands.commandTimeoutAllowlist.description%"
				},
				"shofer.preventCompletionWithOpenTodos": {
					"type": "boolean",
					"default": false,
					"description": "%commands.preventCompletionWithOpenTodos.description%"
				},
				"shofer.vsCodeLmModelSelector": {
					"type": "object",
					"properties": {
						"vendor": {
							"type": "string",
							"description": "%settings.vsCodeLmModelSelector.vendor.description%"
						},
						"family": {
							"type": "string",
							"description": "%settings.vsCodeLmModelSelector.family.description%"
						}
					},
					"description": "%settings.vsCodeLmModelSelector.description%"
				},
				"shofer.customStoragePath": {
					"type": "string",
					"default": "",
					"description": "%settings.customStoragePath.description%"
				},
				"shofer.enableCodeActions": {
					"type": "boolean",
					"default": true,
					"description": "%settings.enableCodeActions.description%"
				},
				"shofer.autoImportSettingsPath": {
					"type": "string",
					"default": "",
					"description": "%settings.autoImportSettingsPath.description%"
				},
				"shofer.maximumIndexedFilesForFileSearch": {
					"type": "number",
					"default": 10000,
					"minimum": 5000,
					"maximum": 500000,
					"description": "%settings.maximumIndexedFilesForFileSearch.description%"
				},
				"shofer.apiRequestTimeout": {
					"type": "number",
					"default": 600,
					"minimum": 0,
					"maximum": 3600,
					"description": "%settings.apiRequestTimeout.description%"
				},
				"shofer.newTaskRequireTodos": {
					"type": "boolean",
					"default": false,
					"description": "%settings.newTaskRequireTodos.description%"
				},
				"shofer.codeIndex.embeddingBatchSize": {
					"type": "number",
					"default": 60,
					"minimum": 1,
					"maximum": 200,
					"description": "%settings.codeIndex.embeddingBatchSize.description%"
				},
				"shofer.debug": {
					"type": "boolean",
					"default": false,
					"description": "%settings.debug.description%"
				},
				"shofer.debugProxy.enabled": {
					"type": "boolean",
					"default": false,
					"description": "%settings.debugProxy.enabled.description%",
					"markdownDescription": "%settings.debugProxy.enabled.description%"
				},
				"shofer.debugProxy.serverUrl": {
					"type": "string",
					"default": "http://127.0.0.1:8888",
					"description": "%settings.debugProxy.serverUrl.description%",
					"markdownDescription": "%settings.debugProxy.serverUrl.description%"
				},
				"shofer.debugProxy.tlsInsecure": {
					"type": "boolean",
					"default": false,
					"description": "%settings.debugProxy.tlsInsecure.description%",
					"markdownDescription": "%settings.debugProxy.tlsInsecure.description%"
				},
				"shofer.enableLlmProviderIntegration": {
					"type": "boolean",
					"default": false,
					"description": "%settings.enableLlmProviderIntegration.description%",
					"markdownDescription": "%settings.enableLlmProviderIntegration.description%"
				}
			}
		},
		"walkthroughs": [
			{
				"id": "shofer.getStarted",
				"title": "Get Started with Shofer",
				"description": "Learn how to use Shofer to code faster with AI.",
				"steps": [
					{
						"id": "welcome",
						"title": "Welcome to Shofer",
						"description": "Shofer is an open-source, complete replacement for GitHub Copilot that helps you write, refactor, and debug code.\n\nLet's get you set up!",
						"media": {
							"markdown": "media/walkthrough/welcome.md"
						}
					},
					{
						"id": "openSidebar",
						"title": "Open Shofer",
						"description": "Click the Shofer icon in the Activity Bar or run:\n\n[Open Shofer](command:workbench.view.extension.shofer-ActivityBar)\n\nInstall Shofer and open the sidebar to get started.",
						"media": {
							"markdown": "media/walkthrough/open-sidebar.md"
						},
						"completionEvents": [
							"onView:shofer.SidebarProvider"
						]
					},
					{
						"id": "chooseMode",
						"title": "Choose a Mode",
						"description": "Select a mode that fits your task. Learn about each mode's available tool categories.",
						"media": {
							"markdown": "media/walkthrough/choose-mode.md"
						}
					},
					{
						"id": "configureProvider",
						"title": "Configure an AI Provider",
						"description": "Choose an AI model and provider for Shofer to use. You can configure this later in the Settings panel.\n\n[Open Settings](command:shofer.settingsButtonClicked)",
						"media": {
							"markdown": "media/walkthrough/configure-provider.md"
						},
						"completionEvents": [
							"onCommand:shofer.settingsButtonClicked"
						]
					},
					{
						"id": "startTask",
						"title": "Start Your First Task",
						"description": "Type a message to Shofer in the chat to get started on your first task!\n\n[New Task](command:shofer.plusButtonClicked)",
						"media": {
							"markdown": "media/walkthrough/start-task.md"
						},
						"completionEvents": [
							"onCommand:shofer.plusButtonClicked"
						]
					},
					{
						"id": "switchTasks",
						"title": "Switch Between Tasks",
						"description": "Shofer supports parallel tasks — switch between multiple AI conversations at once via the TaskSelector.\n\n[Open Tasks](command:shofer.tasksButtonClicked)",
						"media": {
							"markdown": "media/walkthrough/switch-tasks.md"
						},
						"completionEvents": [
							"onCommand:shofer.tasksButtonClicked"
						]
					},
					{
						"id": "exploreSettings",
						"title": "Explore Settings",
						"description": "Configure Shofer to your liking — adjust providers, modes, prompts, and more.\n\n[Open Settings](command:shofer.settingsButtonClicked)",
						"media": {
							"markdown": "media/walkthrough/explore-settings.md"
						}
					},
					{
						"id": "specialFiles",
						"title": "Special Files",
						"description": "Learn about .shoferignore, AGENTS.md, .shofermodes, and the .shofer/ directory that control Shofer's behavior.",
						"media": {
							"markdown": "media/walkthrough/special-files.md"
						}
					},
					{
						"id": "documentation",
						"title": "Learn More",
						"description": "Visit the Shofer documentation for in-depth guides and tutorials.\n\n[Open Documentation](command:shofer.walkthrough.openDocumentation)",
						"media": {
							"markdown": "media/walkthrough/learn-more.md"
						},
						"completionEvents": [
							"onCommand:shofer.walkthrough.openDocumentation"
						]
					},
					{
						"id": "roocodeUsers",
						"title": "Migrating from Roo-Code",
						"description": "Roo-Code is sunsetting — Shofer is the natural migration path with parallel tasks, async MCP, semantic search, and worktree support.\n\n[Read the Roo-Code Migration Guide](command:shofer.walkthrough.openRoocodeGuide)",
						"media": {
							"markdown": "media/walkthrough/roocode-users.md"
						},
						"completionEvents": [
							"onCommand:shofer.walkthrough.openRoocodeGuide"
						]
					},
					{
						"id": "copilotUsers",
						"title": "Migrating from GitHub Copilot",
						"description": "Coming from Copilot? Shofer gives you full model choice, local-first privacy, parallel tasks, and 50+ native tools.\n\n[Read the Copilot Migration Guide](command:shofer.walkthrough.openCopilotGuide)",
						"media": {
							"markdown": "media/walkthrough/copilot-users.md"
						},
						"completionEvents": [
							"onCommand:shofer.walkthrough.openCopilotGuide"
						]
					},
					{
						"id": "community",
						"title": "Join the Community",
						"description": "Connect with other Shofer users on Discord and Reddit.\n\n[Join Discord](command:shofer.walkthrough.joinDiscord)",
						"media": {
							"markdown": "media/walkthrough/community.md"
						},
						"completionEvents": [
							"onCommand:shofer.walkthrough.joinDiscord"
						]
					},
					{
						"id": "worktrees",
						"title": "Next Steps: Git Worktrees",
						"description": "Run parallel tasks on different branches — all in one VS Code window. Create, switch, and manage worktrees from Shofer's UI.",
						"media": {
							"markdown": "media/walkthrough/worktrees.md"
						}
					},
					{
						"id": "ragIndexing",
						"title": "Next Steps: Code & Git Log Indexing",
						"description": "Build a semantic search index of your codebase and git history for lightning-fast AI context gathering.",
						"media": {
							"markdown": "media/walkthrough/rag-indexing.md"
						}
					},
					{
						"id": "assistantAgent",
						"title": "Next Steps: Assistant Agent",
						"description": "A persistent, read-only AI companion that accumulates codebase knowledge over time — survives tasks and restarts.",
						"media": {
							"markdown": "media/walkthrough/assistant-agent.md"
						}
					},
					{
						"id": "complete",
						"title": "You're All Set!",
						"description": "Congratulations! You're ready to code with Shofer.\n\nHappy coding! 🚀",
						"media": {
							"markdown": "media/walkthrough/complete.md"
						}
					}
				]
			}
		]
	},
	"scripts": {
		"lint": "eslint . --ext=ts --max-warnings=0",
		"check-types": "tsc --noEmit",
		"pretest": "turbo run bundle --cwd ..",
		"test": "vitest run",
		"format": "prettier --write .",
		"bundle": "node esbuild.mjs",
		"vscode:prepublish": "pnpm bundle --production",
		"vsix": "mkdirp ../bin && sync && vsce package --no-dependencies --out ../bin",
		"publish:marketplace": "vsce publish --no-dependencies && ovsx publish --no-dependencies",
		"watch:bundle": "pnpm bundle --watch",
