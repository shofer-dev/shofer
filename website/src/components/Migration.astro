---
import { rooCodeComparisons, rooCodeMigration } from "../data/migrations";
import { copilotComparisons, copilotMigration } from "../data/copilot";
---

<section id="migration" class="py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="text-sm font-semibold text-accent-amber dark:text-accent-amber uppercase tracking-wider">Migration</span>
      <h2 class="mt-3 text-3xl sm:text-4xl lg:text-5xl font-extrabold text-gray-900 dark:text-white tracking-tight">
        Already using another AI coding tool?
      </h2>
      <p class="mt-4 text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto">
        One-command migration from Roo-Code and GitHub Copilot. Your configuration, modes, and rules come with you.
      </p>
    </div>

    <!-- Roo-Code -->
    <div class="mb-16 lg:mb-20">
      <div class="flex flex-col lg:flex-row gap-8 lg:gap-10 items-start">
        <div class="lg:w-1/3">
          <div class="lg:sticky lg:top-24">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-accent-rose to-accent-amber flex items-center justify-center text-white mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3v10"></path><path d="M12.67 5.5l8.66 5"></path><path d="M12.67 10.5l8.66-5"></path><path d="M9 17a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v2a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2v-2z"></path></svg>
            </div>
            <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-3">{rooCodeMigration.title}</h3>
            <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed mb-4">{rooCodeMigration.description}</p>
            <div class="inline-flex items-center gap-3">
              <code class="px-3 py-2 rounded-lg bg-gray-100 dark:bg-gray-800 text-sm font-mono text-shofer-600 dark:text-shofer-400">{rooCodeMigration.command}</code>
              <a href={rooCodeMigration.docsUrl} class="text-sm font-medium text-gray-400 dark:text-gray-500 hover:text-shofer-600 dark:hover:text-shofer-400 transition-colors">Full guide ↗</a>
            </div>
          </div>
        </div>

        <div class="lg:w-2/3 w-full overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b-2 border-gray-200 dark:border-gray-800">
                <th class="text-left py-3 px-4 font-semibold text-gray-900 dark:text-white">Feature</th>
                <th class="text-left py-3 px-4 font-semibold text-shofer-600 dark:text-shofer-400">Shofer</th>
                <th class="text-left py-3 px-4 font-semibold text-gray-400 dark:text-gray-500">Roo-Code</th>
              </tr>
            </thead>
            <tbody>
              {rooCodeComparisons.map((row) => (
                <tr class="border-b border-gray-100 dark:border-gray-800/50 hover:bg-gray-50 dark:hover:bg-gray-900/50 transition-colors">
                  <td class="py-3 px-4 font-medium text-gray-900 dark:text-white whitespace-nowrap">{row.feature}</td>
                  <td class="py-3 px-4 text-gray-600 dark:text-gray-300">{row.shofer}</td>
                  <td class="py-3 px-4 text-gray-400 dark:text-gray-500">{row.rooCode}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Copilot -->
    <div>
      <div class="flex flex-col lg:flex-row gap-8 lg:gap-10 items-start">
        <div class="lg:w-1/3">
          <div class="lg:sticky lg:top-24">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-shofer-500 flex items-center justify-center text-white mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path></svg>
            </div>
            <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-3">{copilotMigration.title}</h3>
            <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed mb-4">{copilotMigration.description}</p>
            <div class="inline-flex items-center gap-3">
              <code class="px-3 py-2 rounded-lg bg-gray-100 dark:bg-gray-800 text-sm font-mono text-shofer-600 dark:text-shofer-400">{copilotMigration.command}</code>
              <a href={copilotMigration.docsUrl} class="text-sm font-medium text-gray-400 dark:text-gray-500 hover:text-shofer-600 dark:hover:text-shofer-400 transition-colors">Full guide ↗</a>
            </div>
          </div>
        </div>

        <div class="lg:w-2/3 w-full overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b-2 border-gray-200 dark:border-gray-800">
                <th class="text-left py-3 px-4 font-semibold text-gray-900 dark:text-white">Aspect</th>
                <th class="text-left py-3 px-4 font-semibold text-shofer-600 dark:text-shofer-400">Shofer</th>
                <th class="text-left py-3 px-4 font-semibold text-gray-400 dark:text-gray-500">Copilot</th>
              </tr>
            </thead>
            <tbody>
              {copilotComparisons.map((row) => (
                <tr class="border-b border-gray-100 dark:border-gray-800/50 hover:bg-gray-50 dark:hover:bg-gray-900/50 transition-colors">
                  <td class="py-3 px-4 font-medium text-gray-900 dark:text-white whitespace-nowrap">{row.aspect}</td>
                  <td class="py-3 px-4 text-gray-600 dark:text-gray-300">{row.shofer}</td>
                  <td class="py-3 px-4 text-gray-400 dark:text-gray-500">{row.copilot}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</section>
