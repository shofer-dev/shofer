---
import { features } from "../data/features";

// Only features with `detail` get a block here. Workflows links to its own
// dedicated <Workflows /> section instead.
const detailed = features.filter((f) => f.detail);
---

<section class="border-t border-gray-100 dark:border-gray-800/60">
  {
    detailed.map((feature, i) => (
      <div
        id={feature.anchor}
        class:list={[
          "scroll-mt-24 py-20 sm:py-24",
          i % 2 === 1 ? "bg-gray-50 dark:bg-gray-900/40" : "",
        ]}
      >
        <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
          <div class="max-w-2xl mb-10">
            <span class="text-sm font-semibold text-shofer-600 dark:text-shofer-400 uppercase tracking-wider">
              Feature
            </span>
            <h2 class="mt-3 text-2xl sm:text-3xl lg:text-4xl font-extrabold text-gray-900 dark:text-white tracking-tight">
              {feature.title}
            </h2>
            <p class="mt-4 text-lg text-gray-500 dark:text-gray-400 leading-relaxed">{feature.detail}</p>
            <a
              href={feature.docsUrl}
              target="_blank"
              rel="noopener"
              class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-shofer-600 dark:text-shofer-400 hover:text-shofer-700 dark:hover:text-shofer-300 transition-colors"
            >
              Read the full docs
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
            </a>
          </div>

          {(feature.images?.length ?? 0) > 1 ? (
            <div class="fd-carousel relative" data-carousel>
              <div class="overflow-hidden rounded-2xl border border-gray-200 dark:border-gray-800">
                <div class="fd-track flex transition-transform duration-300 ease-out" data-carousel-track>
                  {feature.images!.map((cap) => (
                    <div class="fd-slide w-full flex-shrink-0">
                      <div class="aspect-video w-full bg-gray-100 dark:bg-gray-800/60 flex flex-col items-center justify-center text-center gap-3 p-8">
                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="text-gray-300 dark:text-gray-600"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                        <span class="text-sm font-medium text-gray-500 dark:text-gray-400 max-w-md">{cap}</span>
                        <span class="text-xs uppercase tracking-wider text-gray-400 dark:text-gray-600">Screenshot coming soon</span>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <button
                type="button"
                data-carousel-prev
                aria-label="Previous"
                class="absolute left-3 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full bg-white/90 dark:bg-gray-900/90 border border-gray-200 dark:border-gray-700 shadow flex items-center justify-center text-gray-700 dark:text-gray-200 hover:bg-white dark:hover:bg-gray-800 transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <button
                type="button"
                data-carousel-next
                aria-label="Next"
                class="absolute right-3 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full bg-white/90 dark:bg-gray-900/90 border border-gray-200 dark:border-gray-700 shadow flex items-center justify-center text-gray-700 dark:text-gray-200 hover:bg-white dark:hover:bg-gray-800 transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
              </button>

              <div class="flex justify-center gap-2 mt-4" data-carousel-dots>
                {feature.images!.map((_, di) => (
                  <button type="button" class="fd-dot" data-carousel-dot={di} aria-label={`Go to slide ${di + 1}`} />
                ))}
              </div>
            </div>
          ) : (
            <div class="rounded-2xl border border-gray-200 dark:border-gray-800 overflow-hidden">
              <div class="aspect-video w-full bg-gray-100 dark:bg-gray-800/60 flex flex-col items-center justify-center text-center gap-3 p-8">
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="text-gray-300 dark:text-gray-600"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                <span class="text-sm font-medium text-gray-500 dark:text-gray-400 max-w-md">{feature.images?.[0] ?? feature.title}</span>
                <span class="text-xs uppercase tracking-wider text-gray-400 dark:text-gray-600">Screenshot coming soon</span>
              </div>
            </div>
          )}
        </div>
      </div>
    ))
  }
</section>

<style>
  .fd-dot {
    width: 8px;
    height: 8px;
    border-radius: 9999px;
    background: rgb(209 213 219); /* gray-300 */
    transition:
      background 0.2s,
      transform 0.2s;
  }
  :global(.dark) .fd-dot {
    background: rgb(75 85 99); /* gray-600 */
  }
  .fd-dot[aria-selected="true"] {
    background: rgb(37 99 235); /* shofer-600-ish */
    transform: scale(1.3);
  }
</style>

<script>
  // Generic, multi-instance carousel wiring.
  document.querySelectorAll<HTMLElement>("[data-carousel]").forEach((root) => {
    const track = root.querySelector<HTMLElement>("[data-carousel-track]")
    const slides = root.querySelectorAll(".fd-slide")
    const dots = root.querySelectorAll<HTMLElement>("[data-carousel-dot]")
    if (!track || slides.length === 0) return
    let idx = 0
    const go = (n: number) => {
      idx = (n + slides.length) % slides.length
      track.style.transform = `translateX(-${idx * 100}%)`
      dots.forEach((d, i) => d.setAttribute("aria-selected", i === idx ? "true" : "false"))
    }
    root.querySelector("[data-carousel-prev]")?.addEventListener("click", () => go(idx - 1))
    root.querySelector("[data-carousel-next]")?.addEventListener("click", () => go(idx + 1))
    dots.forEach((d, i) => d.addEventListener("click", () => go(i)))
    go(0)
  })
</script>
