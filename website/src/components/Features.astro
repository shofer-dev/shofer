---
import { features } from "../data/features";

const iconPaths: Record<string, string> = {
  Layers: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 22 8.5 12 15 2 8.5 12 2"></polygon><line x1="12" y1="15" x2="12" y2="22"></line><polygon points="2 13.5 12 20 22 13.5 12 20"></polygon></svg>',
  GitBranch: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="3" x2="6" y2="15"></line><circle cx="18" cy="6" r="3"></circle><circle cx="6" cy="18" r="3"></circle><path d="M18 9a9 9 0 0 1-9 9"></path></svg>',
  TreePine: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 14l-5-5-5 5"></path><path d="M17 21l-5-5-5 5"></path><path d="M12 9V3"></path></svg>',
  Search: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>',
  Bot: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"></rect><circle cx="12" cy="5" r="2"></circle><path d="M12 7v4"></path><line x1="8" y1="16" x2="8" y2="16.01"></line><line x1="16" y1="16" x2="16" y2="16.01"></line></svg>',
  Zap: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>',
};
---

<section id="features" class="py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="text-sm font-semibold text-shofer-600 dark:text-shofer-400 uppercase tracking-wider">Features</span>
      <h2 class="mt-3 text-3xl sm:text-4xl lg:text-5xl font-extrabold text-gray-900 dark:text-white tracking-tight">
        Everything you need to code at the speed of thought
      </h2>
      <p class="mt-4 text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto">
        Shofer packs the most comprehensive tool set of any open-source AI coding agent — from semantic code search to parallel task orchestration.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
      {features.map((feature, i) => (
        <div
          class="card-glow group relative bg-white dark:bg-gray-900 rounded-2xl p-6 sm:p-8 border border-gray-100 dark:border-gray-800 hover:border-shofer-200 dark:hover:border-shofer-800 transition-all duration-300"
          style={`animation-delay: ${i * 100}ms`}
        >
          <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-shofer-50 to-purple-50 dark:from-shofer-950 dark:to-purple-950 flex items-center justify-center text-shofer-600 dark:text-shofer-400 mb-5 group-hover:scale-110 transition-transform duration-300">
            {iconPaths[feature.icon] ? <Fragment set:html={iconPaths[feature.icon]} /> : <span class="text-2xl">{feature.icon}</span>}
          </div>

          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">{feature.title}</h3>
          <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed mb-4">{feature.description}</p>

          <ul class="space-y-2 mb-6">
            {feature.highlights.map((h) => (
              <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-300">
                <span class="mt-1 w-1.5 h-1.5 rounded-full bg-accent-emerald flex-shrink-0" />
                {h}
              </li>
            ))}
          </ul>

          <a
            href={feature.docsUrl}
            class="inline-flex items-center gap-1.5 text-sm font-medium text-shofer-600 dark:text-shofer-400 hover:text-shofer-700 dark:hover:text-shofer-300 transition-colors"
          >
            {feature.docsLabel}
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
