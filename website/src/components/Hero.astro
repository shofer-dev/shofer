---
import { siteConfig } from "../data/navigation";
---

<section class="relative pt-32 pb-20 lg:pt-44 lg:pb-32 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-shofer-50 via-white to-purple-50 dark:from-shofer-950 dark:via-gray-950 dark:to-purple-950 pointer-events-none" />
  <div class="absolute top-20 left-1/4 w-72 h-72 bg-shofer-400/20 dark:bg-shofer-600/10 rounded-full blur-3xl animate-glow-pulse" />
  <div class="absolute top-40 right-1/4 w-96 h-96 bg-accent-purple/10 dark:bg-accent-purple/10 rounded-full blur-3xl" />

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
   <div class="flex items-center justify-center gap-6 xl:gap-10">
    <!-- Left image (placeholder) -->
    <div class="hidden lg:flex w-56 xl:w-72 flex-shrink-0 animate-fade-in">
      <div class="aspect-[3/4] w-full rounded-2xl border-2 border-dashed border-gray-300 dark:border-gray-700 bg-white/50 dark:bg-gray-900/40 backdrop-blur-sm flex flex-col items-center justify-center text-center gap-3 p-6 shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="text-gray-300 dark:text-gray-600"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
        <span class="text-xs uppercase tracking-wider text-gray-400 dark:text-gray-600">Screenshot coming soon</span>
      </div>
    </div>

    <!-- Center: hero content -->
    <div class="text-center flex-1 min-w-0">
    <div class="animate-slide-down">
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-shofer-100 dark:bg-shofer-900 text-shofer-700 dark:text-shofer-300 mb-8 border border-shofer-200 dark:border-shofer-800">
        <span class="w-1.5 h-1.5 rounded-full bg-shofer-500 animate-pulse" />
        Open Source &bull; Apache 2.0
      </span>
    </div>

    <h1 class="animate-fade-in text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-gray-900 dark:text-white max-w-4xl mx-auto leading-[1.1]">
      Parallel multi-agent workflows.
      <br />
      <span class="text-gradient">Provable.</span> <span class="text-gradient">Observable.</span> <span class="text-gradient-rose">Controllable.</span>
    </h1>

    <p class="animate-fade-in mt-6 text-lg sm:text-xl text-gray-500 dark:text-gray-400 max-w-2xl mx-auto leading-relaxed">
      {siteConfig.description}
    </p>

    <div class="animate-slide-up mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="https://github.com/shofer-dev/shofer"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl font-semibold text-white bg-gray-900 dark:bg-white dark:text-gray-900 hover:bg-gray-800 dark:hover:bg-gray-100 transition-colors shadow-lg shadow-gray-900/20"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
        Star on GitHub
      </a>
      <a
        href="https://marketplace.visualstudio.com/items?itemName=shoferdev.shofer"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl font-semibold text-white bg-shofer-600 hover:bg-shofer-700 transition-colors shadow-lg shadow-shofer-600/20"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Install from VS Code Marketplace
      </a>
    </div>

    <div class="animate-fade-in mt-8 flex flex-wrap items-center justify-center gap-3 sm:gap-6 text-sm text-gray-400 dark:text-gray-500">
      <span class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
        Runs locally
      </span>
      <span class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3v10"></path><path d="M12.67 5.5l8.66 5"></path><path d="M12.67 10.5l8.66-5"></path><path d="M9 17a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v2a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2v-2z"></path></svg>
        Multi-agent workflows
      </span>
      <span class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"></polyline><rect x="2" y="7" width="20" height="5"></rect><line x1="12" y1="22" x2="12" y2="7"></line><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path></svg>
        Any model
      </span>
      <span class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"></rect><rect width="7" height="7" x="14" y="3" rx="1"></rect><rect width="7" height="7" x="14" y="14" rx="1"></rect><rect width="7" height="7" x="3" y="14" rx="1"></rect></svg>
        MCP, RAG, Skills, Worktrees, etc
      </span>
    </div>
    </div>
    <!-- Right image (placeholder) -->
    <div class="hidden lg:flex w-56 xl:w-72 flex-shrink-0 animate-fade-in">
      <div class="aspect-[3/4] w-full rounded-2xl border-2 border-dashed border-gray-300 dark:border-gray-700 bg-white/50 dark:bg-gray-900/40 backdrop-blur-sm flex flex-col items-center justify-center text-center gap-3 p-6 shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="text-gray-300 dark:text-gray-600"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
        <span class="text-xs uppercase tracking-wider text-gray-400 dark:text-gray-600">Screenshot coming soon</span>
      </div>
    </div>
   </div>
  </div>
</section>
